# Copy this file to .env and fill in your values
# cp .env.example .env

# --- LLM API Keys (use at least one) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# --- Kubernetes ---
KUBECONFIG=/home/kgms_com_1/.kube/config
TARGET_NAMESPACE=default

# --- Prometheus ---
PROMETHEUS_URL=http://localhost:9090

# --- Chaos Mesh ---
CHAOS_MESH_NAMESPACE=chaos-mesh
CHAOS_MESH_DASHBOARD=http://localhost:2333

# --- Agent Behaviour ---
MAX_CHAOS_ROUNDS=3
RECOVERY_TIMEOUT_SECONDS=120
SENTINEL_POLL_INTERVAL_SECONDS=10
